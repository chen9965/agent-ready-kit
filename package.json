{
  "name": "@chent6767/agent-ready-kit",
  "version": "0.3.1",
  "description": "Local CLI and GitHub Action that scores repo readiness for AI coding agents and generates AGENTS.md, task cards, guard rules, and reports.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agent-ready": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "smoke": "npm run build && node dist/cli.js scan examples/react-vite && node dist/cli.js scan examples/react-vite --json && node dist/cli.js init examples/react-vite --dry-run && node dist/cli.js report examples/react-vite",
    "prepack": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "agents-md",
    "codex",
    "claude-code",
    "developer-tools",
    "cli",
    "repo-audit",
    "github-action",
    "readiness-score",
    "ai-coding"
  ],
  "author": "agent-ready-kit contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chen9965/agent-ready-kit.git"
  },
  "bugs": {
    "url": "https://github.com/chen9965/agent-ready-kit/issues"
  },
  "homepage": "https://github.com/chen9965/agent-ready-kit#readme",
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18.18"
  }
}
